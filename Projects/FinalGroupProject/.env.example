# Alpha Vantage API Key — free tier at https://www.alphavantage.co/support/#api-key
# 25 requests/day on free plan; app auto-falls back to mock data when limit is hit
VITE_ALPHA_VANTAGE_KEY=your_api_key_here

# Socket.io chat server URL
# Development: http://localhost:3001
# Production:  set to the URL of your deployed backend (Railway / Render etc.)
VITE_SOCKET_URL=http://localhost:3001
